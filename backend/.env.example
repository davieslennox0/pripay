DATABASE_URL=sqlite:///./umbra.db
SESSION_SECRET=
FRONTEND_ORIGIN=http://localhost:5173

# Leave SMTP_HOST blank for local dev — magic links are logged to the
# console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@umbra.local
MAGIC_LINK_BASE_URL=http://localhost:5173/verify-email

# Walrus encrypted-blob storage (brief §5). "local" keeps ciphertext on disk
# (WALRUS_LOCAL_DIR) and works offline; set "http" to use the real testnet
# publisher/aggregator below.
WALRUS_BACKEND=local
WALRUS_LOCAL_DIR=./_walrus_blobs
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=1

# 32-byte hex key for record-at-rest encryption (the Seal placeholder, see
# config.py). Leave blank in dev to auto-generate; set a stable value in prod.
RECORD_ENCRYPTION_KEY=

# Multi-chain receiving (brief §8). LI.FI's public API needs no key for
# quotes/status; INTEGRATOR just tags requests for their dashboard.
RECEIVE_AGGREGATOR=lifi
LIFI_API_URL=https://li.quest/v1
LIFI_INTEGRATOR=umbra

# Swap module (brief §10). Aftermath's public API needs no key.
SWAP_VENUE=aftermath
AFTERMATH_API_URL=https://aftermath.finance/api
SWAP_DEFAULT_SLIPPAGE=0.01

# On-chain contract addresses (testnet — see move-contracts/deployed_testnet.json).
SUI_PACKAGE_ID=0xa41a92b7193c3af04e5256931e01fe372c5b627e7b03e9310dc7ef687ebec0e5
SUI_ACCOUNT_REGISTRY=0x537776f0efcb27e2de4e9176879747090f6e89965eca8b9bc8b4e7a7f5ddde19
SUI_HANDLE_REGISTRY=0xfc38865fe2a80d51ec1a0bca73c5b190b64f9a662221e5a31134b26c5b3b0a2d
SUI_ESCROW_VAULT=0x89534acab2785b8363c2880f13b0f6e0c5da69ade18d8c5961bd232ab892f8a8
SUI_REVENUE_VAULT=0xa54e6f05bb08dbc97320d4e9ede74e86c89b83c279ff04ca2991c5b4869c8bd5
# zUSDC (testnet mock, 6 dec) — swap for Circle USDC type on mainnet
ZUSDC_PACKAGE_ID=0x228245f74e01948d43ef584c0e94e160874e7936434e2e390eec7228db2b61ba
ZUSDC_TREASURY_CAP=0x6e4e4afd8c5388d2810fc72e263b77de4efcece57a243888fa8634c86dc4c6e3
